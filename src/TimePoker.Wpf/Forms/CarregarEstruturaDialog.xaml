<Window x:Class="TimePoker.Wpf.Forms.CarregarEstruturaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Carregar estrutura"
        Width="460" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="pack://application:,,,/app.ico">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Text="Estruturas salvas"
                   Style="{StaticResource KpiLabel}" Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Excluir"
                    Click="AoExcluir"
                    Style="{StaticResource ButtonSecondary}"
                    Padding="14,6" Margin="0,0,8,0" />
            <Button Content="Cancelar" IsCancel="True" Click="AoCancelar"
                    Style="{StaticResource ButtonSecondary}" Padding="14,6" Margin="0,0,8,0" />
            <Button Content="Carregar" IsDefault="True" Click="AoCarregar"
                    Style="{StaticResource ButtonPrimary}" Padding="14,6" />
        </StackPanel>
        <ListBox x:Name="Lista"
                 Background="{StaticResource CardBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource GoldSoftBrush}"
                 FontSize="14"
                 MouseDoubleClick="AoCarregar" />
    </DockPanel>
</Window>
