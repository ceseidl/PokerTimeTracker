<Window x:Class="TimePoker.Wpf.Forms.SalvarComoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Salvar estrutura"
        Width="460" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="pack://application:,,,/app.ico">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Text="Nome da estrutura"
                   Style="{StaticResource KpiLabel}" Margin="0,0,0,8" />
        <TextBox x:Name="TxtNome"
                 DockPanel.Dock="Top"
                 Background="{StaticResource CardBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource GoldSoftBrush}"
                 Padding="8,6"
                 FontSize="14" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" IsCancel="True" Click="AoCancelar"
                    Style="{StaticResource ButtonSecondary}" Padding="14,6" Margin="0,0,8,0" />
            <Button Content="Salvar" IsDefault="True" Click="AoSalvar"
                    Style="{StaticResource ButtonPrimary}" Padding="14,6" />
        </StackPanel>
        <TextBlock />
    </DockPanel>
</Window>
