<Window x:Class="TimePoker.Wpf.Forms.ImportarJogadoresDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Importar do PokerInimigos"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        Icon="pack://application:,,,/app.ico">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Text="Quem está jogando hoje?"
                   Foreground="{StaticResource GoldBrightBrush}"
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top"
                   x:Name="LblOrigem"
                   Foreground="{StaticResource TextDimBrush}"
                   FontSize="11" FontStyle="Italic" Margin="0,0,0,10" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Selecionar todos"     Click="AoMarcarTodos"     Style="{StaticResource ButtonSecondary}" Padding="8,3" MinHeight="0" Height="26" Margin="0,0,4,0" />
            <Button Content="Limpar"               Click="AoLimpar"          Style="{StaticResource ButtonSecondary}" Padding="8,3" MinHeight="0" Height="26" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="LblContador"
                       Foreground="{StaticResource TextMuteBrush}"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cancelar" IsCancel="True" Click="AoCancelar"
                    Style="{StaticResource ButtonSecondary}" Padding="14,6" Margin="0,0,8,0" />
            <Button Content="Importar" IsDefault="True" Click="AoImportar"
                    Style="{StaticResource ButtonPrimary}" Padding="14,6" />
        </StackPanel>

        <ListBox x:Name="Lista"
                 Background="{StaticResource CardBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource GoldSoftBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding Marcado, Mode=TwoWay}"
                              Content="{Binding Nome}"
                              Foreground="{StaticResource TextBrush}"
                              FontSize="13" Padding="6,4"
                              Checked="AoMudarSelecao" Unchecked="AoMudarSelecao" />
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </DockPanel>
</Window>
