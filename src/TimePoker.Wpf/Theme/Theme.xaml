<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===========================================================
         Paleta — espelha o Theme.cs do PokerInimigos
         (verde escuro + dourado, alta legibilidade em TV)
         =========================================================== -->
    <Color x:Key="BgColor">#FF0A0E0B</Color>
    <Color x:Key="Bg2Color">#FF11181A</Color>
    <Color x:Key="CardColor">#FF16201C</Color>
    <Color x:Key="Card2Color">#FF1F2D26</Color>
    <Color x:Key="GreenDarkColor">#FF1F3A2A</Color>
    <Color x:Key="GreenDeepColor">#FF142019</Color>
    <Color x:Key="GoldColor">#FFC9A24B</Color>
    <Color x:Key="GoldBrightColor">#FFE5BE6E</Color>
    <Color x:Key="GoldSoftColor">#FF8E7335</Color>
    <Color x:Key="TextColor">#FFF5EFE0</Color>
    <Color x:Key="TextMuteColor">#FFA89F86</Color>
    <Color x:Key="TextDimColor">#FF6E6757</Color>
    <Color x:Key="RedColor">#FFB8404A</Color>
    <Color x:Key="GreenOkColor">#FF6FA67A</Color>

    <SolidColorBrush x:Key="BgBrush"        Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="Bg2Brush"       Color="{StaticResource Bg2Color}" />
    <SolidColorBrush x:Key="CardBrush"      Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="Card2Brush"     Color="{StaticResource Card2Color}" />
    <SolidColorBrush x:Key="GreenDarkBrush" Color="{StaticResource GreenDarkColor}" />
    <SolidColorBrush x:Key="GreenDeepBrush" Color="{StaticResource GreenDeepColor}" />
    <SolidColorBrush x:Key="GoldBrush"      Color="{StaticResource GoldColor}" />
    <SolidColorBrush x:Key="GoldBrightBrush" Color="{StaticResource GoldBrightColor}" />
    <SolidColorBrush x:Key="GoldSoftBrush"  Color="{StaticResource GoldSoftColor}" />
    <SolidColorBrush x:Key="TextBrush"      Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMuteBrush"  Color="{StaticResource TextMuteColor}" />
    <SolidColorBrush x:Key="TextDimBrush"   Color="{StaticResource TextDimColor}" />
    <SolidColorBrush x:Key="RedBrush"       Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="GreenOkBrush"   Color="{StaticResource GreenOkColor}" />

    <!-- ===========================================================
         Estilos comuns
         =========================================================== -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GoldSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource CardPanel}">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="BorderThickness" Value="3,1,1,1" />
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}" />
    </Style>

    <Style x:Key="KpiLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="KpiValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GoldBrightBrush}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="KpiSub" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMuteBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="HeaderTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GoldBrightBrush}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="Tagline" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource GoldSoftBrush}" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Botão padrão (controle) -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GreenDarkBrush}" />
        <Setter Property="Foreground" Value="{StaticResource GoldBrightBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="brd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="brd" Property="Background" Value="{StaticResource GreenOkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ButtonSecondary" TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

</ResourceDictionary>
